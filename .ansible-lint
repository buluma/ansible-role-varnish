---
#
# Ansible managed
#
exclude_paths:
  - meta/preferences.yml
  - molecule/default/prepare.yml
  - molecule/default/converge.yml
  - molecule/default/verify.yml
  - molecule/default/collections.yml
  - .cache
  - .github
  - .ansible/
  - .ansible/**
  - requirements.yml

enable_list:
  - name[prefix]
